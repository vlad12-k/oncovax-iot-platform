# MQTT
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_TOPIC=oncovax/telemetry

# InfluxDB
INFLUX_URL=http://influxdb:8086
INFLUX_ORG=oncovax
INFLUX_BUCKET=telemetry
INFLUX_TOKEN=dev-token-change-me

# MongoDB
MONGO_URI=mongodb://mongodb:27017
MONGO_DB=oncovax
MONGO_COLLECTION=audit_events

# API
API_HOST=0.0.0.0
API_PORT=8000

# Alert rule
TEMP_THRESHOLD=8.0
CONSECUTIVE_BREACH_REQUIRED=1
