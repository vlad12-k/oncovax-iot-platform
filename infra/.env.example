# =============================================================================
# OncoVax IoT Platform – Environment Configuration Example
# Copy this file to .env and fill in values appropriate for your environment.
# Do NOT commit your real .env file to source control.
# =============================================================================

# --- MQTT broker ---
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_TOPIC=oncovax/telemetry
# Optional comma-separated extra topics for worker compatibility subscriptions.
# Keep empty by default to preserve current legacy topic behavior.
MQTT_TOPICS=
# Optional explicit simulator compatibility topic. Example:
# MQTT_SIMULATOR_COMPAT_TOPIC=oncovax/telemetry/simulator
MQTT_SIMULATOR_COMPAT_TOPIC=

# --- InfluxDB ---
INFLUX_URL=http://influxdb:8086
INFLUX_ORG=oncovax
INFLUX_BUCKET=telemetry
# Generate a secure random token for non-dev deployments
INFLUX_TOKEN=change-me-to-a-secure-random-token

# --- MongoDB (local dev) ---
MONGO_URI=mongodb://mongodb:27017
# For MongoDB Atlas, use the full SRV connection string, e.g.:
# MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_DB=oncovax
MONGO_COLLECTION=audit_events

# --- FastAPI service ---
API_HOST=0.0.0.0
API_PORT=8000

# CORS allowed origins (comma-separated).
# Only needed if the API is accessed from a different origin than the dashboard.
# Leave empty to restrict to same-origin requests only (recommended default).
# Example: CORS_ALLOWED_ORIGINS=https://your-domain.example.com
CORS_ALLOWED_ORIGINS=

# --- Alert detection rule ---
# Temperature readings above this threshold trigger an excursion alert
TEMP_THRESHOLD=8.0
# Number of consecutive breaches required before an alert is emitted
CONSECUTIVE_BREACH_REQUIRED=1
# Cooldown (seconds) to suppress duplicate active alerts per device+metric
ALERT_DEDUP_COOLDOWN_SECONDS=300

# --- InfluxDB init (used by docker-compose for first-run setup) ---
DOCKER_INFLUXDB_INIT_MODE=setup
DOCKER_INFLUXDB_INIT_USERNAME=admin
DOCKER_INFLUXDB_INIT_PASSWORD=change-me-to-a-secure-password
DOCKER_INFLUXDB_INIT_ORG=oncovax
DOCKER_INFLUXDB_INIT_BUCKET=telemetry
DOCKER_INFLUXDB_INIT_ADMIN_TOKEN=change-me-to-a-secure-random-token

# --- Grafana ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me-to-a-secure-password
GF_USERS_ALLOW_SIGN_UP=false
